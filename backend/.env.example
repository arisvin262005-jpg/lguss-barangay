PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=30m

# AES Encryption
AES_SECRET_KEY=32_char_aes_key_change_this_now!

# CouchDB (optional - PouchDB works standalone)
COUCHDB_URL=http://localhost:5984
COUCHDB_USER=admin
COUCHDB_PASSWORD=password
COUCHDB_DB_NAME=barangay_db

# Rate Limiting
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_WINDOW_MINUTES=15

# App
APP_NAME=Barangay Management System
BARANGAY_MUNICIPALITY=Mamburao
BARANGAY_PROVINCE=Occidental Mindoro
