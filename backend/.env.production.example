PORT=5000
NODE_ENV=production

# JWT — PALITAN NG MALAKAS NA SECRET SA PRODUCTION!
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_IN_RAILWAY
JWT_EXPIRES_IN=8h

# AES Encryption — PALITAN DIN ITO!
AES_SECRET_KEY=CHANGE_THIS_32_CHAR_KEY_IN_RAILWAY

# CouchDB (optional — PouchDB works standalone offline)
COUCHDB_URL=
COUCHDB_USER=
COUCHDB_PASSWORD=
COUCHDB_DB_NAME=barangay_db

# Frontend URL for CORS — I-set ang iyong actual na Vercel URL
FRONTEND_URL=https://lguss.vercel.app
FRONTEND_URL_CUSTOM=

# Rate Limiting
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_WINDOW_MINUTES=15

# App Info
APP_NAME=Barangay Management System
BARANGAY_MUNICIPALITY=Mamburao
BARANGAY_PROVINCE=Occidental Mindoro

# NVIDIA NIM API (Llama 3.3 70B)
NVIDIA_API_KEY=YOUR_NVIDIA_API_KEY_HERE
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
